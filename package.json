{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:llm": "vitest run --reporter=verbose --config vitest.llm.config.ts",
    "seed": "npx tsx scripts/seed-sample-violations.ts",
    "deploy": "pnpm build && npx wrangler pages deploy dist --project-name slopcop",
    "deploy:router": "cd router && npx wrangler deploy"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/history": "^0.19.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "compromise": "^14.15.0",
    "diff": "^8.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "retext": "^9.0.0",
    "retext-indefinite-article": "^5.0.0"
  }
}
